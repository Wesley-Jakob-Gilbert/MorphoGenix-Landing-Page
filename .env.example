# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env` to git.

# ---- Notion integration ----
# 1. Go to https://www.notion.so/profile/integrations
# 2. Create a new internal integration, copy the "Internal Integration Secret"
# 3. Open the MorphoGenix Beta Waitlist database in Notion -> "..." menu ->
#    "Connections" -> add your new integration. This grants it write access.
NOTION_TOKEN=secret_your_integration_token_here

# The MorphoGenix Beta Waitlist database ID (already created in your workspace).
# The landing page uses the DATABASE ID, not the data source ID.
NOTION_DATABASE_ID=2fdab5cfd494473aa2d41d04e09ef6c0

# ---- App ----
APP_ENV=development
